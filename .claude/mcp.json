{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {
        "UPSTASH_CONTEXT7_API_KEY": "TU_UPSTASH_CONTEXT7_API_KEY"
      },
      "description": "Live documentation lookup — CRITICAL for accurate code generation"
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "TU_BRAVE_API_KEY"
      },
      "description": "Web search via Brave Search API"
    }
  }
}
