{
  "env": {
    "API_TIMEOUT_MS": "3000000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_PACKAGE_MANAGER": "bun",
    "CLAUDE_AUTO_MEMORY_ENABLED": "true"
  },
  "permissions": {
    "allow": [
      "Read:*",
      "Glob:*",
      "Grep:*",
      "Edit:**/*.ts",
      "Edit:**/*.js",
      "Edit:**/*.tsx",
      "Edit:**/*.css",
      "Edit:**/*.json",
      "Edit:**/*.md",
      "Edit:.claude/ralph-loop.local.md",
      "Bash:git *",
      "Bash:npm *",
      "Bash:pnpm *",
      "Bash:yarn *",
      "Bash:bun *",
      "Bash:/Users/prueba/.claude/plugins/cache/claude-plugins-official/ralph-loop/*",
      "Bash:/Users/prueba/.claude/plugins/cache/claude-plugins-official/*/scripts/*",
      "Bash(mv /Users/prueba/.claude/commands-archive/git-commit.md /Users/prueba/.claude/commands/)",
      "Bash(mv /Users/prueba/.claude/commands-archive/debug.md /Users/prueba/.claude/commands/)",
      "Bash(mv /Users/prueba/.claude/commands-archive/deploy.md /Users/prueba/.claude/commands/)",
      "mcp__brave-search__brave_web_search",
      "mcp__brave-search__brave_news_search",
      "mcp__brave-search__brave_image_search",
      "mcp__context7_context7__query-docs",
      "mcp__context7_context7__resolve-library-id"
    ],
    "deny": [
      "Bash:rm -rf *",
      "Bash:sudo *",
      "Bash:curl *",
      "Bash:wget *"
    ],
    "defaultMode": "auto"
  },
  "enabledMcpjsonServers": [
    "context7",
    "brave-search"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebSearch",
        "hooks": [
          {
            "type": "prompt",
            "prompt": "The user requested a web search but the WebSearch tool is broken (returns error 400). Instead of calling WebSearch, call mcp__brave-search__brave_web_search with the same query. Extract the query from $ARGUMENTS. Report the results as if you had done a normal web search."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/auto-format.sh",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $0 }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/Users/prueba/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "remember@claude-plugins-official": true,
    "firecrawl@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "github@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "andrej-karpathy-skills@karpathy-skills": true,
    "plugin-dev@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "ralph-loop@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    }
  },
  "language": "spanish",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "autoMemory": {
    "enabled": true,
    "maxFiles": 50,
    "maxTokens": 80000
  },
  "_meta": {
    "version": "1.4",
    "lastModified": "2026-04-11",
    "description": "UNIFIED: Single config. context7 + brave-search MCP. Async hooks. github disabled."
  }
}
